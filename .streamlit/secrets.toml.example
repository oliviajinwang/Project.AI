# Copy this file to .streamlit/secrets.toml and fill in real values.
# .streamlit/secrets.toml is gitignored -- never commit real secrets.

# Required for the "Ask BrainGuard AI" assistant's extended, OpenAI-backed
# responses (utils/assistant.py). Without this key, the assistant still
# answers common questions locally via its built-in FAQ table for free, and
# falls back to a "not configured" message for anything else -- the app
# runs fine without it, just with a smaller assistant.
OPENAI_API_KEY = "sk-..."

# Optional -- which OpenAI model the assistant calls. Defaults to
# "gpt-5-nano" if omitted.
OPENAI_MODEL = "gpt-5-nano"

# Invite code required to create a clinician account on the Clinic Access
# page (views/clinic_login.py). Set a private value here on any public
# deployment so strangers can't self-register into the patient dashboard.
# If omitted, it falls back to the CLINIC_SIGNUP_CODE env var, then to the
# documented default "BRAINGUARD-CLINIC" (fine for local dev only).
CLINIC_SIGNUP_CODE = "change-me-to-something-private"
